<Window x:Class="Lab_7_9_Contacts.ContactAdd"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Lab_7_9_Contacts"
        mc:Ignorable="d"
        Title="ContactAdd" Height="450" Width="650">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <WrapPanel Grid.Row="0" Margin="0,10,0,10" HorizontalAlignment="Center">
            <StackPanel Margin="10">
                <TextBlock Text="Name:" FontWeight="Bold"/>
                <TextBox x:Name="NameTextBox" Width="200"/>
            </StackPanel>
            <StackPanel Margin="10">
                <TextBlock Text="Age:" FontWeight="Bold"/>
                <TextBox x:Name="AgeTextBox" Width="200"/>
            </StackPanel>
            <StackPanel Margin="10">
                <TextBlock Text="City:" FontWeight="Bold"/>
                <TextBox x:Name="CityTextBox" Width="200"/>
            </StackPanel>
            <StackPanel Margin="10">
                <TextBlock Text="Phone:" FontWeight="Bold"/>
                <TextBox x:Name="PhoneTextBox" Width="200"/>
            </StackPanel>
        </WrapPanel>

        <WrapPanel Grid.Row="1" Margin="0,10,0,10" HorizontalAlignment="Center">
            <Button Content="Save Contact" Click="SaveContact_Click" Margin="5" Padding="5"/>
            <Button Content="Cancel" Click="Cancel_Click" Margin="5" Padding="5"/>
        </WrapPanel>
    </Grid>
</Window>
